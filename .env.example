# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=documents
POSTGRES_USER=postgres
POSTGRES_PASSWORD=example
JOBS_TABLE=jobs

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rag_docs

# RAG Configuration
RAG_DEFAULT_LIMIT=5
RAG_MAX_TOKENS=1000
RAG_SCORE_THRESHOLD=0.35

# RAG Chunking Configuration
RAG_CHUNK_TARGET_WORDS=150
RAG_CHUNK_MAX_WORDS=250
RAG_CHUNK_OVERLAP_WORDS=30

# Worker Identity Configuration
WORKER_ID=
WORKER_NAME=
HEARTBEAT_INTERVAL=15

# Worker Capabilities Configuration
# Set to "true" to disable LLM tasks (keywords, key-point, ask)
WORKER_DISABLE_LLM=false
# Set to "true" to disable embedding tasks (embedding, search, ingest-content, ask)
WORKER_DISABLE_EMBEDDINGS=false

# Task Filtering Configuration
# Comma-separated list of task types to control which tasks this worker processes.
# Available tasks: detect-language, document-extraction, embedding, keywords,
#   key-point, summarize, translate, entity-extraction, search, ask,
#   ingest-content, delete-vectors, dataset-stats
#
# If WORKER_ENABLED_TASKS is set, ONLY those tasks will be processed.
# WORKER_DISABLED_TASKS excludes specific tasks from processing.
# Both filters apply after capability checks.
WORKER_ENABLED_TASKS=
WORKER_DISABLED_TASKS=

# Background Processing Hours (24h format)
BACKGROUND_HOURS_START=2
BACKGROUND_HOURS_END=6

# File Storage Configuration
DOCUMENTS_STORAGE_DIR=../documents
