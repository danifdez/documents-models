#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$SCRIPT_DIR"

# ── Colors ──
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'
BOLD='\033[1m'
DIM='\033[2m'

info()  { printf "${CYAN}[INFO]${NC}  %s\n" "$*"; }
ok()    { printf "${GREEN}[OK]${NC}    %s\n" "$*"; }
warn()  { printf "${YELLOW}[WARN]${NC}  %s\n" "$*"; }
fail()  { printf "${RED}[ERROR]${NC} %s\n" "$*" >&2; exit 1; }

ask() {
  local prompt="$1" default="$2"
  printf "  ${BOLD}%s${NC} ${DIM}[%s]${NC}: " "$prompt" "$default"
  read -r REPLY
  REPLY="${REPLY:-$default}"
}

# ── Load root .env defaults ──
if [ -f "$ROOT_DIR/.env" ]; then
  set -a
  # shellcheck disable=SC1091
  source "$ROOT_DIR/.env"
  set +a
fi

# ── Configure .env ──
if [ -f ".env" ]; then
  ok ".env already exists (skipping)"
else
  echo ""
  printf "${BOLD}${CYAN}── Models environment configuration ──${NC}\n"
  printf "${DIM}  Press Enter to accept the default value shown in brackets.${NC}\n"
  echo ""

  ask "PostgreSQL host" "${POSTGRES_HOST:-localhost}";       PG_HOST="$REPLY"
  ask "PostgreSQL port" "${POSTGRES_PORT:-5432}";            PG_PORT="$REPLY"
  ask "PostgreSQL database" "${POSTGRES_DB:-documents}";     PG_DB="$REPLY"
  ask "PostgreSQL user" "${POSTGRES_USER:-postgres}";        PG_USER="$REPLY"
  ask "PostgreSQL password" "${POSTGRES_PASSWORD:-example}"; PG_PASS="$REPLY"
  ask "Qdrant host" "${QDRANT_HOST:-localhost}";             QD_HOST="$REPLY"
  ask "Qdrant port" "${QDRANT_PORT:-6333}";                  QD_PORT="$REPLY"
  ask "Qdrant collection name" "rag_docs";                   QD_COLL="$REPLY"
  ask "RAG default limit" "5";                               RAG_LIM="$REPLY"
  ask "RAG max tokens" "1000";                               RAG_TOK="$REPLY"
  ask "RAG score threshold" "0.35";                          RAG_TH="$REPLY"
  ask "RAG chunk target words" "150";                        CH_TARGET="$REPLY"
  ask "RAG chunk max words" "250";                           CH_MAX="$REPLY"
  ask "RAG chunk overlap words" "30";                        CH_OVER="$REPLY"
  ask "Heartbeat interval (seconds)" "15";                   HB="$REPLY"
  ask "Disable LLM tasks (true/false)" "false";              DIS_LLM="$REPLY"
  ask "Disable embeddings tasks (true/false)" "false";       DIS_EMB="$REPLY"
  ask "Background hours start (0-23)" "2";                   BG_START="$REPLY"
  ask "Background hours end (0-23)" "6";                     BG_END="$REPLY"
  ask "Documents storage directory" "../documents";          STORAGE="$REPLY"

  cat > ".env" <<EOF
# Database Configuration
POSTGRES_HOST=$PG_HOST
POSTGRES_PORT=$PG_PORT
POSTGRES_DB=$PG_DB
POSTGRES_USER=$PG_USER
POSTGRES_PASSWORD=$PG_PASS
JOBS_TABLE=jobs

# Qdrant Configuration
QDRANT_HOST=$QD_HOST
QDRANT_PORT=$QD_PORT
QDRANT_URL=http://$QD_HOST:$QD_PORT
QDRANT_COLLECTION=$QD_COLL

# RAG Configuration
RAG_DEFAULT_LIMIT=$RAG_LIM
RAG_MAX_TOKENS=$RAG_TOK
RAG_SCORE_THRESHOLD=$RAG_TH

# RAG Chunking Configuration
RAG_CHUNK_TARGET_WORDS=$CH_TARGET
RAG_CHUNK_MAX_WORDS=$CH_MAX
RAG_CHUNK_OVERLAP_WORDS=$CH_OVER

# Worker Identity Configuration
WORKER_ID=
WORKER_NAME=
HEARTBEAT_INTERVAL=$HB

# Worker Capabilities Configuration
WORKER_DISABLE_LLM=$DIS_LLM
WORKER_DISABLE_EMBEDDINGS=$DIS_EMB

# Task Filtering Configuration
WORKER_ENABLED_TASKS=
WORKER_DISABLED_TASKS=

# Background Processing Hours (24h format)
BACKGROUND_HOURS_START=$BG_START
BACKGROUND_HOURS_END=$BG_END

# File Storage Configuration
DOCUMENTS_STORAGE_DIR=$STORAGE
EOF
  ok "Created .env"
fi

# ── Check Python ──
PYTHON=""
for cmd in python3 python; do
  if command -v "$cmd" >/dev/null 2>&1; then
    PYTHON="$cmd"
    break
  fi
done
[ -n "$PYTHON" ] || fail "Python 3 is not installed."

PY_VERSION=$($PYTHON --version 2>&1)
info "$PY_VERSION detected"

# ── Create virtual environment ──
if [ ! -d ".venv" ]; then
  info "Creating virtual environment..."
  $PYTHON -m venv .venv
  ok "Created .venv"
else
  ok ".venv already exists"
fi

# ── Activate venv ──
source .venv/bin/activate

info "Upgrading pip..."
pip install --upgrade pip -q

# ── Install base dependencies ──
info "Installing base dependencies..."
pip install -r requirements.txt
ok "Base dependencies installed"

# ── Detect CUDA / GPU ──
HAS_CUDA=0

# Method 1: nvidia-smi
if command -v nvidia-smi >/dev/null 2>&1; then
  if nvidia-smi >/dev/null 2>&1; then
    HAS_CUDA=1
  fi
fi

# Method 2: Check if nvcc is available
if [ "$HAS_CUDA" -eq 0 ] && command -v nvcc >/dev/null 2>&1; then
  HAS_CUDA=1
fi

# Method 3: Check for CUDA libraries
if [ "$HAS_CUDA" -eq 0 ] && [ -d "/usr/local/cuda" ]; then
  HAS_CUDA=1
fi

# ── Install GPU dependencies if CUDA detected ──
if [ "$HAS_CUDA" -eq 1 ]; then
  ok "CUDA detected"
  if nvidia-smi >/dev/null 2>&1; then
    nvidia-smi --query-gpu=name,memory.total --format=csv,noheader 2>/dev/null | while read -r line; do
      info "  GPU: $line"
    done
  fi
  info "Installing GPU dependencies (CUDA 12.6 wheels)..."
  pip install -r requirements-gpu.txt
  ok "GPU dependencies installed"
else
  warn "No CUDA detected — installing CPU-only mode"
  info "The service will run on CPU. This is fully supported but slower for ML tasks."
fi

# ── Install spaCy models ──
info "Installing spaCy language models..."
pip install --no-cache-dir en_core_web_sm -f https://github.com/explosion/spacy-models/releases -q
ok "spaCy en_core_web_sm installed"

if [ "$HAS_CUDA" -eq 1 ]; then
  info "Installing spaCy transformer model (GPU)..."
  pip install --no-cache-dir en_core_web_trf -f https://github.com/explosion/spacy-models/releases -q
  ok "spaCy en_core_web_trf installed"
else
  info "Installing spaCy large model (CPU)..."
  pip install --no-cache-dir en_core_web_lg -f https://github.com/explosion/spacy-models/releases -q 2>/dev/null && ok "spaCy en_core_web_lg installed" || warn "en_core_web_lg not available, using en_core_web_sm"
fi

deactivate

# ── Summary ──
echo ""
printf "${GREEN}============================================${NC}\n"
if [ "$HAS_CUDA" -eq 1 ]; then
  printf "${GREEN}  Models installation complete! (GPU mode)${NC}\n"
else
  printf "${GREEN}  Models installation complete! (CPU mode)${NC}\n"
fi
printf "${GREEN}============================================${NC}\n"
echo ""
echo "  Activate venv:   source .venv/bin/activate"
echo "  Start worker:    python jobs.py"
echo ""
if [ "$HAS_CUDA" -eq 0 ]; then
  echo "  Note: Running in CPU-only mode."
  echo "  If you install CUDA later, re-run this script to enable GPU support."
  echo ""
fi
