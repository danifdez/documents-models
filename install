#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$SCRIPT_DIR"

# ── Colors ──
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'
BOLD='\033[1m'
DIM='\033[2m'

info()  { printf "${CYAN}[INFO]${NC}  %s\n" "$*"; }
ok()    { printf "${GREEN}[OK]${NC}    %s\n" "$*"; }
warn()  { printf "${YELLOW}[WARN]${NC}  %s\n" "$*"; }
fail()  { printf "${RED}[ERROR]${NC} %s\n" "$*" >&2; exit 1; }

ask() {
  local prompt="$1" default="$2"
  printf "  ${BOLD}%s${NC} ${DIM}[%s]${NC}: " "$prompt" "$default"
  read -r REPLY
  REPLY="${REPLY:-$default}"
}

ask_yn() {
  local prompt="$1" default="$2"
  printf "  ${BOLD}%s${NC} ${DIM}[%s]${NC}: " "$prompt" "$default"
  read -r REPLY
  REPLY="${REPLY:-$default}"
  [[ "$REPLY" =~ ^[Yy] ]]
}

# ── Create config directory ──
mkdir -p config/tasks

# ── Configure config.json ──
if [ -f "config/config.json" ]; then
  ok "config/config.json already exists (skipping)"
else
  if [ ! -f "common/config.default.json" ]; then
    fail "common/config.default.json not found"
  fi

  cp common/config.default.json config/config.json
  ok "Created config/config.json from defaults"

  echo ""
  printf "${BOLD}${CYAN}── Models configuration ──${NC}\n"
  printf "${DIM}  Press Enter to accept the default value shown in brackets.${NC}\n"
  echo ""

  # ── Database ──
  printf "${BOLD}  Database${NC}\n"
  ask "PostgreSQL host" "localhost";       PG_HOST="$REPLY"
  ask "PostgreSQL port" "5432";            PG_PORT="$REPLY"
  ask "PostgreSQL database" "documents";   PG_DB="$REPLY"
  ask "PostgreSQL user" "postgres";        PG_USER="$REPLY"
  ask "PostgreSQL password" "example";     PG_PASS="$REPLY"
  echo ""

  # ── Qdrant ──
  ENABLE_QDRANT=true
  if ask_yn "Enable Qdrant/RAG?" "yes"; then
    printf "${BOLD}  Qdrant${NC}\n"
    ask "Qdrant host" "localhost";         QD_HOST="$REPLY"
    ask "Qdrant port" "6333";              QD_PORT="$REPLY"
    ask "Qdrant collection name" "rag_docs"; QD_COLL="$REPLY"
  else
    ENABLE_QDRANT=false
    QD_HOST="localhost"
    QD_PORT="6333"
    QD_COLL="rag_docs"
    warn "Qdrant disabled — embedding tasks will be disabled"
  fi
  echo ""

  # ── Storage ──
  ask "Documents storage directory" "../documents"; STORAGE="$REPLY"
  echo ""

  # ── Apply configuration using Python ──
  info "Writing configuration..."

  python3 -c "
import json

with open('config/config.json', 'r') as f:
    cfg = json.load(f)

cfg['database']['host'] = '$PG_HOST'
cfg['database']['port'] = int('$PG_PORT')
cfg['database']['name'] = '$PG_DB'
cfg['database']['user'] = '$PG_USER'
cfg['database']['password'] = '$PG_PASS'

cfg['qdrant']['enabled'] = $( [ "$ENABLE_QDRANT" = true ] && echo 'True' || echo 'False' )
cfg['qdrant']['host'] = '$QD_HOST'
cfg['qdrant']['port'] = int('$QD_PORT')
cfg['qdrant']['collection'] = '$QD_COLL'

cfg['storage']['documents_dir'] = '$STORAGE'

# If Qdrant disabled, disable embeddings
if not cfg['qdrant']['enabled']:
    cfg['worker']['disable_embeddings'] = True

with open('config/config.json', 'w') as f:
    json.dump(cfg, f, indent=2)
    f.write('\n')
"

  ok "Configuration saved to config/config.json"
fi

# ── Sync feature flags from backend .env (if available) ──
BACKEND_ENV="$ROOT_DIR/backend/.env"
if [ -f "$BACKEND_ENV" ]; then
  info "Syncing feature flags from backend .env..."
  python3 -c "
import json, os

backend_env = '$BACKEND_ENV'
env_vars = {}
with open(backend_env) as f:
    for line in f:
        line = line.strip()
        if line and not line.startswith('#') and '=' in line:
            key, val = line.split('=', 1)
            env_vars[key.strip()] = val.strip()

cfg_path = 'config/config.json'
with open(cfg_path) as f:
    cfg = json.load(f)

feature_map = {
    'FEATURE_ENTITIES': 'entities',
    'FEATURE_DATASETS': 'datasets',
    'FEATURE_CANVAS': 'canvas',
    'FEATURE_RAG': 'rag',
}

features = cfg.get('features', {})
for env_key, feat_key in feature_map.items():
    val = env_vars.get(env_key, 'true')
    features[feat_key] = val != 'false'
cfg['features'] = features

with open(cfg_path, 'w') as f:
    json.dump(cfg, f, indent=2)
    f.write('\n')
"
  ok "Feature flags synced"
fi

# ── Configure tasks.json ──
if [ -f "config/tasks.json" ]; then
  ok "config/tasks.json already exists (skipping)"
else
  if [ ! -f "common/tasks.default.json" ]; then
    fail "common/tasks.default.json not found"
  fi

  cp common/tasks.default.json config/tasks.json

  # If Qdrant disabled, disable embedding-dependent tasks
  if [ "$ENABLE_QDRANT" = false ]; then
    python3 -c "
import json

with open('config/tasks.json', 'r') as f:
    tasks = json.load(f)

for task_name in ['search', 'ask', 'ingest-content', 'embedding']:
    if task_name in tasks:
        tasks[task_name]['enabled'] = False

with open('config/tasks.json', 'w') as f:
    json.dump(tasks, f, indent=2)
    f.write('\n')
"
  fi

  ok "Created config/tasks.json from defaults"
fi

# ── Check Python ──
PYTHON=""
for cmd in python3 python; do
  if command -v "$cmd" >/dev/null 2>&1; then
    PYTHON="$cmd"
    break
  fi
done
[ -n "$PYTHON" ] || fail "Python 3 is not installed."

PY_VERSION=$($PYTHON --version 2>&1)
info "$PY_VERSION detected"

# ── Check / install ffmpeg (required for audio/video transcription) ──
if command -v ffmpeg >/dev/null 2>&1; then
  FFMPEG_VERSION=$(ffmpeg -version 2>&1 | head -n1)
  ok "ffmpeg detected: $FFMPEG_VERSION"
else
  info "ffmpeg not found — attempting to install..."
  if command -v apt-get >/dev/null 2>&1; then
    sudo apt-get install -y ffmpeg -qq && ok "ffmpeg installed" || warn "Failed to install ffmpeg (try: sudo apt install ffmpeg)"
  elif command -v dnf >/dev/null 2>&1; then
    sudo dnf install -y ffmpeg -q && ok "ffmpeg installed" || warn "Failed to install ffmpeg (try: sudo dnf install ffmpeg)"
  elif command -v brew >/dev/null 2>&1; then
    brew install ffmpeg && ok "ffmpeg installed" || warn "Failed to install ffmpeg (try: brew install ffmpeg)"
  else
    warn "Could not install ffmpeg automatically. Install it manually for audio/video support."
  fi
fi

# ── Create virtual environment ──
if [ ! -d ".venv" ]; then
  info "Creating virtual environment..."
  $PYTHON -m venv .venv
  ok "Created .venv"
else
  ok ".venv already exists"
fi

# ── Activate venv ──
source .venv/bin/activate

info "Upgrading pip..."
pip install --upgrade pip -q

# ── Install base dependencies ──
info "Installing base dependencies..."
pip install -r requirements.txt
ok "Base dependencies installed"

# ── Detect CUDA / GPU ──
HAS_CUDA=0

# Method 1: nvidia-smi
if command -v nvidia-smi >/dev/null 2>&1; then
  if nvidia-smi >/dev/null 2>&1; then
    HAS_CUDA=1
  fi
fi

# Method 2: Check if nvcc is available
if [ "$HAS_CUDA" -eq 0 ] && command -v nvcc >/dev/null 2>&1; then
  HAS_CUDA=1
fi

# Method 3: Check for CUDA libraries
if [ "$HAS_CUDA" -eq 0 ] && [ -d "/usr/local/cuda" ]; then
  HAS_CUDA=1
fi

# ── Install GPU dependencies if CUDA detected ──
if [ "$HAS_CUDA" -eq 1 ]; then
  ok "CUDA detected"
  if nvidia-smi >/dev/null 2>&1; then
    nvidia-smi --query-gpu=name,memory.total --format=csv,noheader 2>/dev/null | while read -r line; do
      info "  GPU: $line"
    done
  fi
  info "Installing GPU dependencies..."
  pip install -r requirements-gpu.txt
  # Force reinstall llama-cpp-python with CUDA support (compile from source)
  info "Compiling llama-cpp-python with CUDA support (this may take a few minutes)..."
  CMAKE_ARGS="-DGGML_CUDA=on" pip install llama-cpp-python --force-reinstall --no-cache-dir
  ok "GPU dependencies installed"
else
  warn "No CUDA detected — installing CPU-only mode"
  info "The service will run on CPU. This is fully supported but slower for ML tasks."
fi

# ── Install spaCy models ──
SPACY_VERSION=$($PYTHON -c "import spacy; print('.'.join(spacy.__version__.split('.')[:2]))")
SPACY_MODELS_URL="https://github.com/explosion/spacy-models/releases/download"

info "Installing spaCy language models (spaCy $SPACY_VERSION)..."
pip install --no-cache-dir "${SPACY_MODELS_URL}/en_core_web_sm-${SPACY_VERSION}.0/en_core_web_sm-${SPACY_VERSION}.0.tar.gz" -q
ok "spaCy en_core_web_sm installed"

if [ "$HAS_CUDA" -eq 1 ]; then
  info "Installing spaCy transformer model (GPU)..."
  pip install --no-cache-dir "${SPACY_MODELS_URL}/en_core_web_trf-${SPACY_VERSION}.0/en_core_web_trf-${SPACY_VERSION}.0.tar.gz" -q
  ok "spaCy en_core_web_trf installed"
else
  info "Installing spaCy large model (CPU)..."
  pip install --no-cache-dir "${SPACY_MODELS_URL}/en_core_web_lg-${SPACY_VERSION}.0/en_core_web_lg-${SPACY_VERSION}.0.tar.gz" -q 2>/dev/null && ok "spaCy en_core_web_lg installed" || warn "en_core_web_lg not available, using en_core_web_sm"
fi

# ── Pre-download HuggingFace models ──
info "Pre-downloading models (this may take a while on first run)..."

$PYTHON -c "
import json, sys

with open('config/tasks.json') as f:
    tasks = json.load(f)

# Embedding model
if tasks.get('embedding', {}).get('enabled', False):
    model = tasks['embedding'].get('model', 'BAAI/bge-small-en-v1.5')
    print(f'  Downloading embedding model: {model}', flush=True)
    from sentence_transformers import SentenceTransformer
    SentenceTransformer(model)
    print(f'  ✓ {model}', flush=True)

# Summarization model
if tasks.get('summarize', {}).get('enabled', False):
    model = tasks['summarize'].get('model', 'facebook/mbart-large-50-one-to-many-mmt')
    print(f'  Downloading summarization model: {model}', flush=True)
    from transformers import AutoTokenizer, AutoModelForSeq2SeqLM
    AutoTokenizer.from_pretrained(model)
    AutoModelForSeq2SeqLM.from_pretrained(model)
    print(f'  ✓ {model}', flush=True)

# Whisper model (transcription)
if tasks.get('transcribe', {}).get('enabled', False):
    model_size = tasks['transcribe'].get('model', 'base')
    print(f'  Downloading whisper model: {model_size}', flush=True)
    from faster_whisper import WhisperModel
    WhisperModel(model_size, device='cpu', compute_type='int8')
    print(f'  ✓ whisper {model_size}', flush=True)

# Diffusion model (image generation)
has_cuda = '$HAS_CUDA' == '1'
if has_cuda and tasks.get('image-generate', {}).get('enabled', False):
    model = tasks['image-generate'].get('model', 'stabilityai/stable-diffusion-xl-base-1.0')
    print(f'  Downloading diffusion model: {model}', flush=True)
    import torch
    from diffusers import AutoPipelineForText2Image
    AutoPipelineForText2Image.from_pretrained(model, torch_dtype=torch.float16, variant='fp16')
    print(f'  ✓ {model}', flush=True)
"
ok "All models pre-downloaded"

deactivate

# ── Summary ──
echo ""
printf "${GREEN}============================================${NC}\n"
if [ "$HAS_CUDA" -eq 1 ]; then
  printf "${GREEN}  Models installation complete! (GPU mode)${NC}\n"
else
  printf "${GREEN}  Models installation complete! (CPU mode)${NC}\n"
fi
printf "${GREEN}============================================${NC}\n"
echo ""
echo "  Configuration: config/config.json, config/tasks.json"
echo "  Activate venv:   source .venv/bin/activate"
echo "  Start worker:    python jobs.py"
echo ""
if [ "$HAS_CUDA" -eq 0 ]; then
  echo "  Note: Running in CPU-only mode."
  echo "  If you install CUDA later, re-run this script to enable GPU support."
  echo ""
fi
