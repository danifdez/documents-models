#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$SCRIPT_DIR"

# ── Colors ──
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'
BOLD='\033[1m'
DIM='\033[2m'

info()  { printf "${CYAN}[INFO]${NC}  %s\n" "$*"; }
ok()    { printf "${GREEN}[OK]${NC}    %s\n" "$*"; }
warn()  { printf "${YELLOW}[WARN]${NC}  %s\n" "$*"; }
fail()  { printf "${RED}[ERROR]${NC} %s\n" "$*" >&2; exit 1; }

ask() {
  local prompt="$1" default="$2"
  printf "  ${BOLD}%s${NC} ${DIM}[%s]${NC}: " "$prompt" "$default"
  read -r REPLY
  REPLY="${REPLY:-$default}"
}

ask_yn() {
  local prompt="$1" default="$2"
  printf "  ${BOLD}%s${NC} ${DIM}[%s]${NC}: " "$prompt" "$default"
  read -r REPLY
  REPLY="${REPLY:-$default}"
  [[ "$REPLY" =~ ^[Yy] ]]
}

# ── Create config directory ──
mkdir -p config/tasks

# ── Configure config.json ──
if [ -f "config/config.json" ]; then
  ok "config/config.json already exists (skipping)"
else
  if [ ! -f "common/config.default.json" ]; then
    fail "common/config.default.json not found"
  fi

  cp common/config.default.json config/config.json
  ok "Created config/config.json from defaults"

  echo ""
  printf "${BOLD}${CYAN}── Models configuration ──${NC}\n"
  printf "${DIM}  Press Enter to accept the default value shown in brackets.${NC}\n"
  echo ""

  # ── Database ──
  printf "${BOLD}  Database${NC}\n"
  ask "PostgreSQL host" "localhost";       PG_HOST="$REPLY"
  ask "PostgreSQL port" "5432";            PG_PORT="$REPLY"
  ask "PostgreSQL database" "documents";   PG_DB="$REPLY"
  ask "PostgreSQL user" "postgres";        PG_USER="$REPLY"
  ask "PostgreSQL password" "example";     PG_PASS="$REPLY"
  echo ""

  # ── Qdrant ──
  ENABLE_QDRANT=true
  if ask_yn "Enable Qdrant/RAG?" "yes"; then
    printf "${BOLD}  Qdrant${NC}\n"
    ask "Qdrant host" "localhost";         QD_HOST="$REPLY"
    ask "Qdrant port" "6333";              QD_PORT="$REPLY"
    ask "Qdrant collection name" "rag_docs"; QD_COLL="$REPLY"
  else
    ENABLE_QDRANT=false
    QD_HOST="localhost"
    QD_PORT="6333"
    QD_COLL="rag_docs"
    warn "Qdrant disabled — embedding tasks will be disabled"
  fi
  echo ""

  # ── Storage ──
  ask "Documents storage directory" "../documents"; STORAGE="$REPLY"
  echo ""

  # ── Apply configuration using Python ──
  info "Writing configuration..."

  python3 -c "
import json

with open('config/config.json', 'r') as f:
    cfg = json.load(f)

cfg['database']['host'] = '$PG_HOST'
cfg['database']['port'] = int('$PG_PORT')
cfg['database']['name'] = '$PG_DB'
cfg['database']['user'] = '$PG_USER'
cfg['database']['password'] = '$PG_PASS'

cfg['qdrant']['enabled'] = $( [ "$ENABLE_QDRANT" = true ] && echo 'True' || echo 'False' )
cfg['qdrant']['host'] = '$QD_HOST'
cfg['qdrant']['port'] = int('$QD_PORT')
cfg['qdrant']['collection'] = '$QD_COLL'

cfg['storage']['documents_dir'] = '$STORAGE'

# If Qdrant disabled, disable embeddings
if not cfg['qdrant']['enabled']:
    cfg['worker']['disable_embeddings'] = True

with open('config/config.json', 'w') as f:
    json.dump(cfg, f, indent=2)
    f.write('\n')
"

  ok "Configuration saved to config/config.json"
fi

# ── Configure tasks.json ──
if [ -f "config/tasks.json" ]; then
  ok "config/tasks.json already exists (skipping)"
else
  if [ ! -f "common/tasks.default.json" ]; then
    fail "common/tasks.default.json not found"
  fi

  cp common/tasks.default.json config/tasks.json

  # If Qdrant disabled, disable embedding-dependent tasks
  if [ "$ENABLE_QDRANT" = false ]; then
    python3 -c "
import json

with open('config/tasks.json', 'r') as f:
    tasks = json.load(f)

for task_name in ['search', 'ask', 'ingest-content', 'embedding']:
    if task_name in tasks:
        tasks[task_name]['enabled'] = False

with open('config/tasks.json', 'w') as f:
    json.dump(tasks, f, indent=2)
    f.write('\n')
"
  fi

  ok "Created config/tasks.json from defaults"
fi

# ── Check Python ──
PYTHON=""
for cmd in python3 python; do
  if command -v "$cmd" >/dev/null 2>&1; then
    PYTHON="$cmd"
    break
  fi
done
[ -n "$PYTHON" ] || fail "Python 3 is not installed."

PY_VERSION=$($PYTHON --version 2>&1)
info "$PY_VERSION detected"

# ── Create virtual environment ──
if [ ! -d ".venv" ]; then
  info "Creating virtual environment..."
  $PYTHON -m venv .venv
  ok "Created .venv"
else
  ok ".venv already exists"
fi

# ── Activate venv ──
source .venv/bin/activate

info "Upgrading pip..."
pip install --upgrade pip -q

# ── Install base dependencies ──
info "Installing base dependencies..."
pip install -r requirements.txt
ok "Base dependencies installed"

# ── Detect CUDA / GPU ──
HAS_CUDA=0

# Method 1: nvidia-smi
if command -v nvidia-smi >/dev/null 2>&1; then
  if nvidia-smi >/dev/null 2>&1; then
    HAS_CUDA=1
  fi
fi

# Method 2: Check if nvcc is available
if [ "$HAS_CUDA" -eq 0 ] && command -v nvcc >/dev/null 2>&1; then
  HAS_CUDA=1
fi

# Method 3: Check for CUDA libraries
if [ "$HAS_CUDA" -eq 0 ] && [ -d "/usr/local/cuda" ]; then
  HAS_CUDA=1
fi

# ── Install GPU dependencies if CUDA detected ──
if [ "$HAS_CUDA" -eq 1 ]; then
  ok "CUDA detected"
  if nvidia-smi >/dev/null 2>&1; then
    nvidia-smi --query-gpu=name,memory.total --format=csv,noheader 2>/dev/null | while read -r line; do
      info "  GPU: $line"
    done
  fi
  info "Installing GPU dependencies (CUDA 12.6 wheels)..."
  pip install -r requirements-gpu.txt
  ok "GPU dependencies installed"
else
  warn "No CUDA detected — installing CPU-only mode"
  info "The service will run on CPU. This is fully supported but slower for ML tasks."
fi

# ── Install spaCy models ──
SPACY_VERSION=$($PYTHON -c "import spacy; print('.'.join(spacy.__version__.split('.')[:2]))")
SPACY_MODELS_URL="https://github.com/explosion/spacy-models/releases/download"

info "Installing spaCy language models (spaCy $SPACY_VERSION)..."
pip install --no-cache-dir "${SPACY_MODELS_URL}/en_core_web_sm-${SPACY_VERSION}.0/en_core_web_sm-${SPACY_VERSION}.0.tar.gz" -q
ok "spaCy en_core_web_sm installed"

if [ "$HAS_CUDA" -eq 1 ]; then
  info "Installing spaCy transformer model (GPU)..."
  pip install --no-cache-dir "${SPACY_MODELS_URL}/en_core_web_trf-${SPACY_VERSION}.0/en_core_web_trf-${SPACY_VERSION}.0.tar.gz" -q
  ok "spaCy en_core_web_trf installed"
else
  info "Installing spaCy large model (CPU)..."
  pip install --no-cache-dir "${SPACY_MODELS_URL}/en_core_web_lg-${SPACY_VERSION}.0/en_core_web_lg-${SPACY_VERSION}.0.tar.gz" -q 2>/dev/null && ok "spaCy en_core_web_lg installed" || warn "en_core_web_lg not available, using en_core_web_sm"
fi

deactivate

# ── Summary ──
echo ""
printf "${GREEN}============================================${NC}\n"
if [ "$HAS_CUDA" -eq 1 ]; then
  printf "${GREEN}  Models installation complete! (GPU mode)${NC}\n"
else
  printf "${GREEN}  Models installation complete! (CPU mode)${NC}\n"
fi
printf "${GREEN}============================================${NC}\n"
echo ""
echo "  Configuration: config/config.json, config/tasks.json"
echo "  Activate venv:   source .venv/bin/activate"
echo "  Start worker:    python jobs.py"
echo ""
if [ "$HAS_CUDA" -eq 0 ]; then
  echo "  Note: Running in CPU-only mode."
  echo "  If you install CUDA later, re-run this script to enable GPU support."
  echo ""
fi
